{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "lint": "eslint --no-error-on-unmatched-pattern src/",
    "lint:fix": "eslint --fix --no-error-on-unmatched-pattern src/",
    "test:unit": "node --test test/unit/**/*.test.js",
    "test:unit:coverage": "c8 --reporter=text --reporter=html node --test test/unit/**/*.test.js",
    "test:integration": "node --test test/integration/**/*.test.js",
    "test:integration:coverage": "c8 --reporter=text --reporter=html node --test test/integration/**/*.test.js",
    "test:api": "node --test test/api/**/*.test.js",
    "test:api:coverage": "c8 --reporter=text --reporter=html node --test test/api/**/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "c8": "^10.1.3",
    "eslint": "^9.21.0",
    "eslint-plugin-security": "^3.0.1"
  }
}
