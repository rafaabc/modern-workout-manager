{
  "name": "workout-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "license": "MIT",
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:backend": "npm --workspace=backend run test:unit && npm --workspace=backend run test:integration && npm --workspace=backend run test:api",
    "test:frontend": "npm --workspace=frontend run test:unit",
    "test": "npm run test:backend && npm run test:frontend",
    "prepare": "husky",
    "start:backend": "npm --workspace=backend run start",
    "start:frontend": "npm --workspace=frontend run dev",
    "test:e2e": "npm --workspace=frontend run test:e2e",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "eslint --fix --no-error-on-unmatched-pattern --config backend/eslint.config.js",
      "prettier --write"
    ],
    "frontend/**/*.{js,vue}": [
      "eslint --fix --no-error-on-unmatched-pattern --config frontend/eslint.config.js",
      "prettier --write"
    ]
  }
}
